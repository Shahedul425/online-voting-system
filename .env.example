# =========================
# Domain
# =========================
DOMAIN=trustvote.live

# =========================
# Keycloak DB
# =========================
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-this-keycloak-db-password

# =========================
# App DB
# =========================
APP_DB_NAME=ovsApp
APP_DB_USER=ovsApp
APP_DB_PASSWORD=change-this-app-db-password

# =========================
# Keycloak admin
# =========================
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-this-keycloak-admin-password

# =========================
# Grafana admin
# =========================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-admin-password

# =========================
# Backend app
# =========================
SPRING_APPLICATION_NAME=demo
SPRING_PROFILES_ACTIVE=prod

SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://trustvote.live/auth/realms/OVS-System
KEYCLOAK_BASE_URL=https://trustvote.live/auth
KEYCLOAK_REALM=OVS-System
KEYCLOAK_CLIENT_ID=ovs_frontend

SPRING_DATASOURCE_URL=jdbc:postgresql://app_db:5432/ovsApp
SPRING_DATASOURCE_USERNAME=ovsApp
SPRING_DATASOURCE_PASSWORD=change-this-app-db-password

SPRING_JPA_DATABASE=postgresql
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=false

MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
MANAGEMENT_METRICS_TAGS_APPLICATION=demo

LOGGING_LEVEL_COM_EXAMPLE_DEMO=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOGGING_LEVEL_ORG_HIBERNATE=WARN
LOGGING_LEVEL_IO_MICROMETER_TRACING=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_BOOT_ACTUATE_AUTOCONFIGURE_TRACING=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY_WEB_FILTERCHAINPROXY=WARN
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY_WEB_AUTHENTICATION_ANONYMOUSAUTHENTICATIONFILTER=WARN
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_BOOT_ACTUATE=INFO
LOGGING_PATTERN_CONSOLE=%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n

SPRING_BATCH_JOB_ENABLED=false
SPRING_BATCH_JDBC_INITIALIZE_SCHEMA=always
SPRING_DOCKER_COMPOSE_ENABLED=false

APP_CORS_ALLOWED_ORIGINS=https://trustvote.live,https://www.trustvote.live

RECEIPT_TOKEN_SECRET=replace-with-a-long-random-secret
LOKI_URL=http://loki:3100/loki/api/v1/push

# =========================
# Grafana subpath config
# =========================
GF_SERVER_ROOT_URL=https://trustvote.live/grafana/
GF_SERVER_SERVE_FROM_SUB_PATH=true