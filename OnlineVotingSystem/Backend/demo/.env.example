SPRING_APPLICATION_NAME=demo
SPRING_PROFILES_ACTIVE=dev

SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:8081/realms/OVS-System
KEYCLOAK_BASE_URL=http://localhost:8081
KEYCLOAK_REALM=OVS-System
KEYCLOAK_CLIENT_ID=ovs_frontend

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/ovsApp
SPRING_DATASOURCE_USERNAME=ovsApp
SPRING_DATASOURCE_PASSWORD=change-this-app-db-password

SPRING_JPA_DATABASE=postgresql
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=false

MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
MANAGEMENT_METRICS_TAGS_APPLICATION=demo

LOGGING_LEVEL_COM_EXAMPLE_DEMO=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOGGING_LEVEL_ORG_HIBERNATE=WARN
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=DEBUG

SPRING_BATCH_JOB_ENABLED=false
SPRING_BATCH_JDBC_INITIALIZE_SCHEMA=always
SPRING_DOCKER_COMPOSE_ENABLED=false

APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

RECEIPT_TOKEN_SECRET=replace-with-a-local-secret
LOKI_URL=http://localhost:3100/loki/api/v1/push